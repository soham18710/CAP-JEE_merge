{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/upload", "destination": "app.py" },
    { "source": "/progress", "destination": "app.py" },
    { "source": "/download", "destination": "app.py" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
